<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pos_keyboard_shortcut.SearchProductPopup">
        <div class="popup search-product-popup" style="max-width:520px;width:100%;">
            <div class="popup-header d-flex align-items-center justify-content-between px-4 py-3 border-bottom">
                <h3 class="m-0 fw-semibold" t-esc="props.title"/>
            </div>
            <div class="popup-body px-4 py-3">
                <div class="mb-3">
                    <input
                        t-ref="searchInput"
                        type="text"
                        class="form-control form-control-lg"
                        placeholder="Type product name, barcode, or SKU..."
                        t-on-input="onInput"
                        t-on-keydown="onKeyDown"
                        autocomplete="off"
                        spellcheck="false"
                    />
                </div>
                <div class="search-results" style="max-height:320px;overflow-y:auto;">
                    <t t-if="filteredProducts.length === 0 and state.searchWord">
                        <div class="text-center text-muted py-4">
                            <i class="fa fa-search fa-2x mb-2 d-block opacity-50"/>
                            No products found for "<strong t-esc="state.searchWord"/>"
                        </div>
                    </t>
                    <t t-elif="!state.searchWord">
                        <div class="text-center text-muted py-4">
                            <i class="fa fa-keyboard-o fa-2x mb-2 d-block opacity-50"/>
                            Start typing to search products
                        </div>
                    </t>
                    <t t-else="">
                        <div class="list-group">
                            <t t-foreach="filteredProducts" t-as="product" t-key="product.id">
                                <button
                                    type="button"
                                    t-att-class="'list-group-item list-group-item-action d-flex align-items-center gap-3 py-2 px-3' + (product_index === state.selectedIndex ? ' active' : '')"
                                    t-on-click="() => this._addProduct(product)"
                                    t-on-mouseenter="() => { this.state.selectedIndex = product_index; }"
                                >
                                    <div class="flex-grow-1 text-start">
                                        <div class="fw-semibold lh-sm" t-esc="product.display_name"/>
                                        <small t-if="product.default_code" class="text-muted" t-esc="product.default_code"/>
                                    </div>
                                    <span class="badge bg-primary rounded-pill ms-auto" t-esc="formatPrice(product.lst_price)"/>
                                </button>
                            </t>
                        </div>
                    </t>
                </div>
                <div class="mt-2 d-flex gap-3 text-muted small justify-content-center">
                    <span><kbd>↑↓</kbd> Navigate</span>
                    <span><kbd>Enter</kbd> Add to order</span>
                    <span><kbd>Esc</kbd> Close</span>
                </div>
            </div>
            <div class="popup-footer d-flex justify-content-end px-4 py-3 border-top">
                <button class="btn btn-secondary" t-on-click="cancel" t-esc="props.cancelText"/>
            </div>
        </div>
    </t>
</templates>
